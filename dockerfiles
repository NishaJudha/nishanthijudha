pipeline {
    agent  label {'built-in'}
    
    environment { 
        DOCKER_IMAGE = "nishajudha/custom-nginx"
        DOCKER_TAG = "latest" // Uses Jenkins build number as the tag 
    }
    
    stages {
        stage('Checkout') {
            steps {
                // Pulls the latest code from your SCM (Github/Bitbucket)
                git branch: 'main',
              url: 'https://github.com/NishaJudha/guvi-devopslearning-nisha.git'
            }
        }
        
        stage('Build Image') {
            steps {
                script {
                    // Build image using the Dockerfile in root directory
                    sh "docker build -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                    sh "docker tag ${DOCKER_IMAGE}:${DOCKER_TAG} ${DOCKER_IMAGE}:latest"
                }
            }
        }
        
        stage('Push to Docker hub') {
            steps {
                withCredentials {[usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'USER",
                    passwordVariable: 'PASS'
                )]}    {
                    sh 'echo $PASS' | docker login -u $USER --password-stdin
                }


                }
            }
        }


         stage('pus image') {
             steps {
                // Removes local images to save diskspace on the Jenkins agent 
                sh "docker push ${DOCKER_IMAGE}:latest"
             }
         }
    }
}
